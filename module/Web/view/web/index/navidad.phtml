                d: 19,
                dl: 3.2,
                fs: '0.8em'
            }
        ];
        var symbols = ['❄', '❅', '❆', '*', '✦'];
        snowData.forEach(function(s) {
            var el = document.createElement('span');
            el.className = 'snow-particle';
            el.textContent = symbols[Math.floor(Math.random() * symbols.length)];
            el.style.left = s.l;
            el.style.fontSize = s.fs;
            el.style.animationDuration = s.d + 's';
            el.style.animationDelay = s.dl + 's';
            document.body.appendChild(el);
        });

        /* ---- Lightbox ---- */
        var total = <?= $santaCount ?>;
        var current = 0;
        var base = '<?= str_replace("'", "\\'", $santaBase) ?>';

        window.openNavLightbox = function(idx) {
            current = idx;
            updateLB();
            document.getElementById('navLightbox').classList.add('active');
            document.body.style.overflow = 'hidden';
        };
        window.closeNavLightbox = function() {
            document.getElementById('navLightbox').classList.remove('active');
            document.body.style.overflow = '';
        };
        window.navLightboxChange = function(dir) {
            current = (current + dir + total) % total;
            updateLB();
        };

        function updateLB() {
            document.getElementById('navLightboxImg').src = base + (current + 1) + '.jpg';
            document.getElementById('navLightboxCounter').textContent = (current + 1) + ' / ' + total;
        }

        document.getElementById('navLightbox').addEventListener('click', function(e) {
            if (e.target === this) closeNavLightbox();
        });
        document.addEventListener('keydown', function(e) {
            var lb = document.getElementById('navLightbox');
            if (!lb.classList.contains('active')) return;
            if (e.key === 'Escape') closeNavLightbox();
            if (e.key === 'ArrowLeft') navLightboxChange(-1);
            if (e.key === 'ArrowRight') navLightboxChange(1);
        });
    })();
</script>